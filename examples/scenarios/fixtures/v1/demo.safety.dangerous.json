      "limitations": []
    },
    "android": {
      "status": "required",
      "capabilities": [
        "runtime.snapshot",
        "automation.actions",
        "automation.safety",
        "exploration.graph"
      ],
      "limitations": []
    }
  },
  "profiles": [
