{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vistrea.dev/schema/v1/validation.schema.json",
  "title": "Vistrea Validation and Build Diff Types",
  "$defs": {
    "FindingSeverity": {
      "enum": ["info", "warning", "error", "critical"]
    },
    "FindingCategory": {
      "enum": [
        "structural",
        "visual",
        "behavioral",
        "accessibility",
        "design",
        "build_diff",
        "policy",
        "custom"
      ]
    },
    "ValidationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "kind", "captured_at", "extensions"],
      "properties": {
        "evidence_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "kind": {
          "enum": [
            "runtime_snapshot",
            "screenshot",
            "video",
            "runtime_event",
            "design_reference",
            "log",
            "trace",
            "measurement",
            "other"
          ]
        },
        "captured_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "source_ref": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "artifact_ref": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "region": {
          "$ref": "https://vistrea.dev/schema/v1/geometry.schema.json#/$defs/NonEmptyRect"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      },
      "anyOf": [
        { "properties": { "source_ref": true }, "required": ["source_ref"] },
        { "properties": { "artifact_ref": true }, "required": ["artifact_ref"] }
      ]
    },
    "ValidationFindingCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "open", "suppressed", "resolved", "by_severity"],
      "properties": {
        "total": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "open": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "suppressed": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "resolved": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["info", "warning", "error", "critical"],
          "properties": {
            "info": {
              "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
            },
            "warning": {
              "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
            },
            "error": {
              "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
            },
            "critical": {
              "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
            }
          }
        }
      }
    },
    "ValidationRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_run_id",
        "protocol_version",
        "operation_id",
        "target",
        "rule_set",
        "state",
        "created_at",
        "updated_at",
        "revision",
        "finding_counts",
        "extensions"
      ],
      "properties": {
        "validation_run_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "operation_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "target": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "rule_set": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "state": {
          "enum": ["queued", "running", "succeeded", "failed", "cancelled"]
        },
        "created_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "started_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "completed_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "finding_counts": { "$ref": "#/$defs/ValidationFindingCounts" },
        "error": {
          "$ref": "https://vistrea.dev/schema/v1/operation.schema.json#/$defs/VistreaError"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "state": { "const": "queued" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "started_at": false,
              "completed_at": false,
              "error": false
            }
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "running" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "started_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "completed_at": false,
              "error": false
            },
            "required": ["started_at"]
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "succeeded" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "started_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "completed_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "error": false
            },
            "required": ["started_at", "completed_at"]
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "failed" } },
            "required": ["state"]
          },
          "then": {
            "properties": {
              "started_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "completed_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "error": {
                "$ref": "https://vistrea.dev/schema/v1/operation.schema.json#/$defs/VistreaError"
              }
            },
            "required": ["started_at", "completed_at", "error"]
          }
        },
        {
          "if": {
            "properties": { "state": { "const": "cancelled" } },
            "required": ["state"]
          },
          "then": {
            "required": ["completed_at", "error"],
            "properties": {
              "completed_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "error": {
                "type": "object",
                "properties": { "code": { "const": "cancelled" } },
                "required": ["code"]
              }
            }
          }
        }
      ]
    },
    "ValidationFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "protocol_version",
        "validation_run_id",
        "rule_id",
        "category",
        "severity",
        "status",
        "message",
        "subject",
        "evidence",
        "detected_at",
        "updated_at",
        "revision",
        "extensions"
      ],
      "properties": {
        "finding_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "validation_run_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "rule_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/StableId"
        },
        "category": { "$ref": "#/$defs/FindingCategory" },
        "severity": { "$ref": "#/$defs/FindingSeverity" },
        "status": { "enum": ["open", "suppressed", "resolved"] },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "subject": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "expected": {
          "$ref": "https://vistrea.dev/schema/v1/operation.schema.json#/$defs/JsonValue"
        },
        "actual": {
          "$ref": "https://vistrea.dev/schema/v1/operation.schema.json#/$defs/JsonValue"
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationEvidence" }
        },
        "active_suppression_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "detected_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "resolved_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "suppressed" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "active_suppression_id": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
              },
              "resolved_at": false
            },
            "required": ["active_suppression_id"]
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "resolved" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "resolved_at": {
                "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
              },
              "active_suppression_id": false
            },
            "required": ["resolved_at"]
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "open" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "active_suppression_id": false,
              "resolved_at": false
            }
          }
        }
      ]
    },
    "ValidationSuppression": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppression_id",
        "protocol_version",
        "finding_id",
        "reason_code",
        "justification",
        "created_by",
        "created_at",
        "extensions"
      ],
      "properties": {
        "suppression_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "finding_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "reason_code": {
          "enum": [
            "false_positive",
            "accepted_risk",
            "known_issue",
            "environment_variance",
            "other"
          ]
        },
        "justification": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "created_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "created_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "expires_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "ValidationBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "run", "findings", "suppressions", "extensions"],
      "properties": {
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "run": { "$ref": "#/$defs/ValidationRun" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationFinding" }
        },
        "suppressions": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationSuppression" }
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "BuildDiffEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_id", "kind", "domains", "summary", "evidence", "extensions"],
      "properties": {
        "entry_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "kind": { "enum": ["added", "removed", "changed", "regressed", "improved"] },
        "domains": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "structural",
              "visual",
              "behavioral",
              "accessibility",
              "design",
              "validation"
            ]
          }
        },
        "severity": { "$ref": "#/$defs/FindingSeverity" },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "left_subject": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "right_subject": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationEvidence" }
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      },
      "anyOf": [
        { "properties": { "left_subject": true }, "required": ["left_subject"] },
        { "properties": { "right_subject": true }, "required": ["right_subject"] }
      ],
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "added" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["right_subject"],
            "properties": { "left_subject": false }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "removed" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["left_subject"],
            "properties": { "right_subject": false }
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "enum": ["changed", "regressed", "improved"] }
            },
            "required": ["kind"]
          },
          "then": { "required": ["left_subject", "right_subject"] }
        }
      ]
    },
    "BuildDiffSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "added", "removed", "changed", "regressed", "improved"],
      "properties": {
        "total": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "added": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "removed": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "changed": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "regressed": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        },
        "improved": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafeUnsignedInteger"
        }
      }
    },
    "BuildDiff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_diff_id",
        "protocol_version",
        "operation_id",
        "left_build",
        "right_build",
        "created_at",
        "summary",
        "entries",
        "extensions"
      ],
      "properties": {
        "build_diff_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "operation_id": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7"
        },
        "left_build": {
          "allOf": [
            {
              "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
            },
            {
              "type": "object",
              "properties": { "kind": { "const": "build" } },
              "required": ["kind"]
            }
          ]
        },
        "right_build": {
          "allOf": [
            {
              "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
            },
            {
              "type": "object",
              "properties": { "kind": { "const": "build" } },
              "required": ["kind"]
            }
          ]
        },
        "created_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "summary": { "$ref": "#/$defs/BuildDiffSummary" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/BuildDiffEntry" }
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    }
  },
  "$ref": "#/$defs/ValidationRun"
}
