{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vistrea.dev/schema/v1/commit.schema.json",
  "title": "Vistrea Commit and Version Types",
  "$defs": {
    "CommitId": {
      "type": "string",
      "pattern": "^commit:sha256:[0-9a-f]{64}$"
    },
    "RefName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "pattern": "^(?:users|teams|builds|baselines|releases)/[A-Za-z0-9][A-Za-z0-9._-]{0,63}(?:/[A-Za-z0-9][A-Za-z0-9._-]{0,63})*$"
    },
    "TagName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}(?:/[A-Za-z0-9][A-Za-z0-9._-]{0,63})*$"
    },
    "CommitRoots": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime_graph": { "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef" },
        "wiki": { "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef" },
        "design": { "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef" },
        "reviews": { "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef" },
        "validation": { "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef" }
      }
    },
    "CommitManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "parents",
        "created_at",
        "author",
        "message",
        "roots",
        "object_hashes",
        "extensions"
      ],
      "properties": {
        "protocol_version": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion" },
        "parents": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/CommitId" }
        },
        "created_at": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp" },
        "author": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "message": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "build_context": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef" },
        "roots": { "$ref": "#/$defs/CommitRoots" },
        "object_hashes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "extensions": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions" }
      }
    },
    "Commit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_id", "manifest"],
      "properties": {
        "commit_id": { "$ref": "#/$defs/CommitId" },
        "manifest": { "$ref": "#/$defs/CommitManifest" }
      }
    },
    "Ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "commit_id", "revision"],
      "properties": {
        "name": { "$ref": "#/$defs/RefName" },
        "commit_id": { "$ref": "#/$defs/CommitId" },
        "revision": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafePositiveInteger" }
      }
    },
    "Tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "commit_id", "created_at", "created_by", "extensions"],
      "properties": {
        "name": { "$ref": "#/$defs/TagName" },
        "commit_id": { "$ref": "#/$defs/CommitId" },
        "created_at": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp" },
        "created_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "message": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "extensions": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions" }
      }
    },
    "VersionSelector": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "commit_id"],
          "properties": {
            "kind": { "const": "commit" },
            "commit_id": { "$ref": "#/$defs/CommitId" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "ref_name"],
          "properties": {
            "kind": { "const": "ref" },
            "ref_name": { "$ref": "#/$defs/RefName" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "tag_name"],
          "properties": {
            "kind": { "const": "tag" },
            "tag_name": { "$ref": "#/$defs/TagName" }
          }
        }
      ]
    },
    "RefUpdatePrecondition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "expected_commit_id"],
          "properties": {
            "mode": { "const": "must_match" },
            "expected_commit_id": { "$ref": "#/$defs/CommitId" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": { "mode": { "const": "must_not_exist" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "authorization"],
          "properties": {
            "mode": { "const": "force" },
            "authorization": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef" }
          }
        }
      ]
    },
    "WorkingChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["change_id", "operation", "resource", "extensions"],
      "properties": {
        "change_id": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7" },
        "operation": { "enum": ["upsert", "delete"] },
        "resource": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef" },
        "payload": { "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef" },
        "expected_revision": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/SafePositiveInteger" },
        "extensions": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "operation": { "const": "upsert" } },
            "required": ["operation"]
          },
          "then": {
            "properties": { "payload": true },
            "required": ["payload"]
          }
        },
        {
          "if": {
            "properties": { "operation": { "const": "delete" } },
            "required": ["operation"]
          },
          "then": {
            "not": {
              "properties": { "payload": true },
              "required": ["payload"]
            }
          }
        }
      ]
    },
    "WorkingSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "working_set_id",
        "base_commit_id",
        "revision",
        "created_at",
        "updated_at",
        "changes",
        "extensions"
      ],
      "properties": {
        "working_set_id": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/TypedUuidV7" },
        "base_commit_id": { "$ref": "#/$defs/CommitId" },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "created_at": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp" },
        "updated_at": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp" },
        "changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/WorkingChange" }
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    }
  },
  "$ref": "#/$defs/Commit"
}
