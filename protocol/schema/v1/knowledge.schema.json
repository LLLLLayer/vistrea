{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vistrea.dev/schema/v1/knowledge.schema.json",
  "title": "Vistrea Knowledge Models",
  "$defs": {
    "WikiNodeId": {
      "type": "string",
      "pattern": "^wiki_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "WikiLinkId": {
      "type": "string",
      "pattern": "^wikilink_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "KnowledgeCollectionId": {
      "type": "string",
      "pattern": "^collection_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "InlineKnowledgeContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storage", "media_type", "text", "extensions"],
      "properties": {
        "storage": { "const": "inline" },
        "media_type": { "enum": ["text/markdown", "text/plain"] },
        "text": { "type": "string", "maxLength": 1048576 },
        "language": { "type": "string", "minLength": 2, "maxLength": 64 },
        "redaction_profile": { "type": "string", "minLength": 1, "maxLength": 128 },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "ObjectKnowledgeContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storage", "object", "extensions"],
      "properties": {
        "storage": { "const": "object" },
        "object": {
          "$ref": "https://vistrea.dev/schema/v1/object.schema.json#/$defs/ObjectRef"
        },
        "excerpt": { "type": "string", "maxLength": 4096 },
        "language": { "type": "string", "minLength": 2, "maxLength": 64 },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "KnowledgeContent": {
      "oneOf": [
        { "$ref": "#/$defs/InlineKnowledgeContent" },
        { "$ref": "#/$defs/ObjectKnowledgeContent" }
      ]
    },
    "WikiNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wiki_node_id",
        "protocol_version",
        "revision",
        "kind",
        "title",
        "content",
        "status",
        "labels",
        "related_resources",
        "attachments",
        "created_at",
        "created_by",
        "updated_at",
        "updated_by",
        "extensions"
      ],
      "properties": {
        "wiki_node_id": { "$ref": "#/$defs/WikiNodeId" },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "kind": {
          "enum": [
            "screen",
            "component",
            "path",
            "requirement",
            "test",
            "design",
            "concept",
            "note"
          ]
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 512 },
        "slug": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "summary": { "type": "string", "maxLength": 4096 },
        "content": { "$ref": "#/$defs/KnowledgeContent" },
        "status": { "enum": ["draft", "published", "archived"] },
        "labels": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
          }
        },
        "related_resources": {
          "type": "array",
          "items": {
            "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
          }
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "https://vistrea.dev/schema/v1/artifact.schema.json#/$defs/ArtifactLink"
          }
        },
        "supersedes_node_id": { "$ref": "#/$defs/WikiNodeId" },
        "created_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "created_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "updated_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "updated_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "WikiLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wiki_link_id",
        "protocol_version",
        "revision",
        "source_node_id",
        "target",
        "relation",
        "created_at",
        "created_by",
        "extensions"
      ],
      "properties": {
        "wiki_link_id": { "$ref": "#/$defs/WikiLinkId" },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "source_node_id": { "$ref": "#/$defs/WikiNodeId" },
        "target": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ResourceRef"
        },
        "relation": {
          "enum": [
            "relates_to",
            "documents",
            "evidence_for",
            "implements",
            "tests",
            "depends_on",
            "supersedes"
          ]
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 256 },
        "annotation": { "$ref": "#/$defs/KnowledgeContent" },
        "created_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "created_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "DraftPublication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "extensions"],
      "properties": {
        "state": { "const": "draft" },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "PublishedPublication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "commit_id",
        "ref_name",
        "published_at",
        "published_by",
        "extensions"
      ],
      "properties": {
        "state": { "const": "published" },
        "commit_id": {
          "$ref": "https://vistrea.dev/schema/v1/commit.schema.json#/$defs/CommitId"
        },
        "ref_name": {
          "$ref": "https://vistrea.dev/schema/v1/commit.schema.json#/$defs/RefName"
        },
        "published_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "published_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "ArchivedPublication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "archived_at", "archived_by", "extensions"],
      "properties": {
        "state": { "const": "archived" },
        "source_commit_id": {
          "$ref": "https://vistrea.dev/schema/v1/commit.schema.json#/$defs/CommitId"
        },
        "archived_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "archived_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "KnowledgePublication": {
      "oneOf": [
        { "$ref": "#/$defs/DraftPublication" },
        { "$ref": "#/$defs/PublishedPublication" },
        { "$ref": "#/$defs/ArchivedPublication" }
      ]
    },
    "KnowledgeCollection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_id",
        "protocol_version",
        "revision",
        "name",
        "node_ids",
        "link_ids",
        "entry_node_ids",
        "publication",
        "created_at",
        "created_by",
        "updated_at",
        "updated_by",
        "extensions"
      ],
      "properties": {
        "collection_id": { "$ref": "#/$defs/KnowledgeCollectionId" },
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "summary": { "type": "string", "maxLength": 4096 },
        "node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/WikiNodeId" }
        },
        "link_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/WikiLinkId" }
        },
        "entry_node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/WikiNodeId" }
        },
        "publication": { "$ref": "#/$defs/KnowledgePublication" },
        "created_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "created_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "updated_at": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Timestamp"
        },
        "updated_by": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ActorRef"
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "KnowledgeBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "revision",
        "nodes",
        "links",
        "collections",
        "extensions"
      ],
      "properties": {
        "protocol_version": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
        },
        "revision": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Revision"
        },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/WikiNode" }
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/$defs/WikiLink" }
        },
        "collections": {
          "type": "array",
          "items": { "$ref": "#/$defs/KnowledgeCollection" }
        },
        "extensions": {
          "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
        }
      }
    },
    "KnowledgeGraph": {
      "$ref": "#/$defs/KnowledgeBundle"
    }
  },
  "$ref": "#/$defs/WikiNode"
}
