{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vistrea.dev/schema/v1/model-coverage.schema.json",
  "title": "Vistrea Data Unit of Work Model Coverage",
  "$defs": {
    "SchemaReferenceList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri-reference",
        "pattern": "^https://vistrea\\.dev/schema/v1/[a-z0-9-]+\\.schema\\.json(?:#/.+)?$"
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "contract",
    "repositories",
    "supporting_models",
    "extensions"
  ],
  "properties": {
    "protocol_version": {
      "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion"
    },
    "contract": { "const": "data-unit-of-work" },
    "repositories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshots",
        "observations",
        "runtime_events",
        "screen_graph",
        "wiki",
        "design_reviews",
        "validation",
        "operations",
        "versions"
      ],
      "properties": {
        "snapshots": { "$ref": "#/$defs/SchemaReferenceList" },
        "observations": { "$ref": "#/$defs/SchemaReferenceList" },
        "runtime_events": { "$ref": "#/$defs/SchemaReferenceList" },
        "screen_graph": { "$ref": "#/$defs/SchemaReferenceList" },
        "wiki": { "$ref": "#/$defs/SchemaReferenceList" },
        "design_reviews": { "$ref": "#/$defs/SchemaReferenceList" },
        "validation": { "$ref": "#/$defs/SchemaReferenceList" },
        "operations": { "$ref": "#/$defs/SchemaReferenceList" },
        "versions": { "$ref": "#/$defs/SchemaReferenceList" }
      }
    },
    "supporting_models": { "$ref": "#/$defs/SchemaReferenceList" },
    "extensions": {
      "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/Extensions"
    }
  }
}
