{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vistrea.dev/schema/v1/fixture-manifest.schema.json",
  "title": "Vistrea Protocol Fixture Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "fixtures"],
  "properties": {
    "protocol_version": { "$ref": "https://vistrea.dev/schema/v1/common.schema.json#/$defs/ProtocolVersion" },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "schema_id", "expectation"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._/-]+\\.json$" },
          "schema_id": { "type": "string", "format": "uri-reference" },
          "expectation": {
            "enum": [
              "schema-valid",
              "json-invalid",
              "schema-invalid",
              "semantic-invalid",
              "compatibility-valid"
            ]
          },
          "semantic_kind": {
            "enum": [
              "runtime-snapshot",
              "runtime-event",
              "runtime-event-batch",
              "object-fixture",
              "workspace",
              "commit"
            ]
          },
          "expected_json_codes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "duplicate_json_key",
                "unsafe_json_integer",
                "invalid_unicode_scalar",
                "invalid_utf8",
                "invalid_json"
              ]
            }
          },
          "expected_schema_errors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["keyword", "instance_path"],
              "properties": {
                "keyword": { "type": "string", "minLength": 1 },
                "instance_path": { "type": "string" },
                "missing_property": { "type": "string", "minLength": 1 },
                "additional_property": { "type": "string", "minLength": 1 }
              }
            }
          },
          "expected_semantic_codes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9._-]*$" }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "expectation": { "const": "json-invalid" } },
              "required": ["expectation"]
            },
            "then": {
              "properties": { "expected_json_codes": true },
              "required": ["expected_json_codes"]
            }
          },
          {
            "if": {
              "properties": { "expectation": { "const": "schema-invalid" } },
              "required": ["expectation"]
            },
            "then": {
              "properties": { "expected_schema_errors": true },
              "required": ["expected_schema_errors"]
            }
          },
          {
            "if": {
              "properties": { "expectation": { "const": "semantic-invalid" } },
              "required": ["expectation"]
            },
            "then": {
              "properties": {
                "semantic_kind": true,
                "expected_semantic_codes": true
              },
              "required": ["semantic_kind", "expected_semantic_codes"]
            }
          }
        ]
      }
    }
  }
}
