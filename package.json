{
  "name": "vistrea",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.14.0 <25"
  },
  "description": "Local-first runtime UI knowledge, design review, exploration, and verification platform.",
  "scripts": {
    "protocol:validate": "node tools/protocol/validate-fixtures.mjs",
    "scenarios:validate": "node examples/scenarios/validate.mjs",
    "typecheck": "tsc --noEmit",
    "build:host": "tsc -p tsconfig.json && node data/metadata/copy-migrations.mjs .build/typescript/data/metadata/migrations",
    "test:contract": "node --test tests/contract/*.test.mjs",
    "test:host-contract": "pnpm build:host && node --test .build/typescript/tests/contract/*.test.js",
    "test:host-integration": "pnpm build:host && node --test .build/typescript/tests/integration/*.test.js",
    "test:agent-adapters": "pnpm build:host && node --test .build/typescript/tests/integration/agent-adapters.test.js",
    "test:e2e:ios-real-vertical": "pnpm build:host && VISTREA_RUN_IOS_REAL_VERTICAL=1 node --test .build/typescript/tests/e2e/ios-real-vertical-loop.test.js",
    "test:e2e:android-real-vertical": "pnpm build:host && VISTREA_RUN_ANDROID_REAL_VERTICAL=1 node --test .build/typescript/tests/e2e/android-real-vertical-loop.test.js",
    "test:e2e:android-real-automation": "pnpm build:host && VISTREA_RUN_ANDROID_REAL_AUTOMATION=1 node --test .build/typescript/tests/e2e/android-real-automation-loop.test.js",
    "test:e2e:ios-real-automation": "pnpm build:host && VISTREA_RUN_IOS_REAL_AUTOMATION=1 node --test .build/typescript/tests/e2e/ios-real-automation-loop.test.js",
    "test:scenarios": "node --test examples/scenarios/tests/*.test.mjs",
    "check": "pnpm protocol:validate && pnpm scenarios:validate && pnpm typecheck && pnpm test:contract && pnpm test:host-contract && pnpm test:host-integration && pnpm test:scenarios",
    "wda": "node tools/automation/wda.mjs"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.14.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1"
  }
}
